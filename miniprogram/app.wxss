page {
  min-height: 100%;
  background: #fff6e8;
  color: #153f3a;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 32rpx;
}

view,
text,
input,
button,
textarea,
picker {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 48rpx 32rpx 68rpx;
  background: linear-gradient(180deg, #fff6e8 0%, #fffaf2 46%, #edf6ef 100%);
}

.hero-card,
.soft-card {
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 40rpx;
  background: rgba(255, 252, 244, 0.96);
  box-shadow: 0 18rpx 44rpx rgba(33, 76, 68, 0.13);
}

.hero-card {
  padding: 52rpx 38rpx;
}

.soft-card {
  margin-top: 28rpx;
  padding: 34rpx;
}

.title {
  color: #0f5d55;
  font-size: 58rpx;
  font-weight: 800;
  line-height: 1.18;
}

.subtitle {
  margin-top: 20rpx;
  color: #936c1d;
  font-size: 34rpx;
  line-height: 1.52;
}

.section-title {
  color: #0f5d55;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.4;
}

.body-text {
  margin-top: 16rpx;
  color: #234a45;
  font-size: 30rpx;
  line-height: 1.72;
}

.primary-button,
.secondary-button {
  width: 100%;
  height: 96rpx;
  margin-top: 24rpx;
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 96rpx;
}

.primary-button {
  color: #fffaf0;
  background: #0f5d55;
  border: 0;
  box-shadow: 0 12rpx 26rpx rgba(15, 93, 85, 0.26);
}

.secondary-button {
  color: #0f5d55;
  background: #fff1c9;
  border: 2rpx solid #f0c65d;
}

.muted {
  color: #6f756c;
  font-size: 26rpx;
  line-height: 1.65;
}

.field {
  margin-top: 28rpx;
}

.label {
  display: block;
  margin-bottom: 14rpx;
  color: #0f5d55;
  font-size: 30rpx;
  font-weight: 800;
}

.input,
.picker-box {
  width: 100%;
  min-height: 88rpx;
  padding: 22rpx 24rpx;
  border: 2rpx solid #d8e4d7;
  border-radius: 26rpx;
  background: #ffffff;
  color: #153f3a;
  font-size: 30rpx;
}

.placeholder {
  color: #9a9a88;
}

.error-box {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  background: #fff0d2;
  color: #8a4a00;
  font-size: 28rpx;
  line-height: 1.6;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 28rpx;
}

.note-tag {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #e8f5ee;
  color: #0f5d55;
  font-size: 24rpx;
  font-weight: 800;
}

.note-tag.gold {
  background: #ffe6a9;
  color: #855f12;
}

.mini-note {
  margin-top: 18rpx;
  color: #66736d;
  font-size: 26rpx;
  line-height: 1.65;
}
