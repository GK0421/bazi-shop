page {
  min-height: 100%;
  background: #f8f1df;
  color: #153f3a;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 32rpx;
}

view,
text,
input,
button,
textarea,
picker {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 44rpx 32rpx 64rpx;
  background: linear-gradient(180deg, #f8f1df 0%, #fff9eb 48%, #f4ead0 100%);
}

.hero-card,
.soft-card {
  border: 4rpx solid #0f5d57;
  border-radius: 28rpx;
  background: #fffaf0;
  box-shadow: 0 14rpx 0 rgba(15, 93, 87, 0.16);
}

.hero-card {
  padding: 48rpx 36rpx;
}

.soft-card {
  margin-top: 28rpx;
  padding: 32rpx;
}

.title {
  color: #0f5d57;
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1.2;
}

.subtitle {
  margin-top: 18rpx;
  color: #806020;
  font-size: 34rpx;
  line-height: 1.55;
}

.section-title {
  color: #0f5d57;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.4;
}

.body-text {
  margin-top: 16rpx;
  color: #234a45;
  font-size: 30rpx;
  line-height: 1.75;
}

.primary-button,
.secondary-button {
  width: 100%;
  height: 96rpx;
  margin-top: 24rpx;
  border-radius: 24rpx;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 96rpx;
}

.primary-button {
  color: #153f3a;
  background: #f2c14e;
  border: 4rpx solid #0f5d57;
  box-shadow: 0 10rpx 0 #d49b23;
}

.secondary-button {
  color: #0f5d57;
  background: #fffaf0;
  border: 4rpx solid #0f5d57;
}

.muted {
  color: #6f756c;
  font-size: 26rpx;
  line-height: 1.65;
}

.field {
  margin-top: 28rpx;
}

.label {
  display: block;
  margin-bottom: 14rpx;
  color: #0f5d57;
  font-size: 30rpx;
  font-weight: 800;
}

.input,
.picker-box {
  width: 100%;
  min-height: 88rpx;
  padding: 22rpx 24rpx;
  border: 3rpx solid #8bb8a8;
  border-radius: 20rpx;
  background: #ffffff;
  color: #153f3a;
  font-size: 30rpx;
}

.placeholder {
  color: #9a9a88;
}

.error-box {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: #fff1d0;
  color: #8a4a00;
  font-size: 28rpx;
  line-height: 1.6;
}
