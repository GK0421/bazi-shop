.report-card {
  margin-bottom: 28rpx;
  padding: 32rpx;
  border: 4rpx solid #0f5d57;
  border-radius: 28rpx;
  background: #fffaf0;
  box-shadow: 0 12rpx 0 rgba(15, 93, 87, 0.14);
}

.card-title {
  margin-bottom: 18rpx;
  color: #0f5d57;
  font-size: 36rpx;
  font-weight: 800;
}

.card-content {
  color: #234a45;
  font-size: 30rpx;
  line-height: 1.75;
}
