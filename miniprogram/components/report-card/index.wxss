.report-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.06);
}
.card-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #2D6A4F;
  margin-bottom: 20rpx;
}
.card-content {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.8;
}
