<view class="container">
  <view class="card">
    <view style="font-size:32rpx;font-weight:bold;color:#2D6A4F;margin-bottom:30rpx;">填写分析信息</view>

    <view class="form-item">
      <text class="form-label">阳历生日 <text style="color:#E55353;">*</text></text>
      <picker mode="date" bindchange="onBirthdayChange" value="{{birthday}}">
        <view class="form-picker">{{birthday || '请选择生日'}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">出生时辰 <text style="color:#E55353;">*</text></text>
      <picker mode="selector" range="{{hours}}" bindchange="onHourChange" value="{{hourIndex}}">
        <view class="form-picker">{{hours[hourIndex] || '请选择时辰'}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">性别 <text style="color:#E55353;">*</text></text>
      <radio-group bindchange="onGenderChange">
        <view style="display:flex;gap:40rpx;margin-top:12rpx;">
          <label style="display:flex;align-items:center;gap:10rpx;">
            <radio value="男" checked="{{gender==='男'}}"/><text>男</text>
          </label>
          <label style="display:flex;align-items:center;gap:10rpx;">
            <radio value="女" checked="{{gender==='女'}}"/><text>女</text>
          </label>
        </view>
      </radio-group>
    </view>

    <view class="form-item">
      <text class="form-label">出生地（可选）</text>
      <input class="form-input" placeholder="如：北京" value="{{location}}" bindinput="onLocationInput" />
    </view>

    <view class="form-item">
      <text class="form-label">备注（可选，仅本地记录）</text>
      <textarea class="form-textarea" placeholder="备注信息，不会提交给服务器" value="{{remark}}" bindinput="onRemarkInput"></textarea>
    </view>

    <button class="btn-primary" bindtap="submit">提交分析</button>
    <button class="btn-secondary" bindtap="goBack" style="margin-top:16rpx;">返回首页</button>
  </view>
</view>
