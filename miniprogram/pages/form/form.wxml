<view class="page">
  <view class="hero-card">
    <view class="tag-row">
      <text class="note-tag">本次推演</text>
      <text class="note-tag gold">不收集详细住址</text>
    </view>
    <view class="title">填写你的出生时间</view>
    <view class="subtitle">信息只用于生成本次文化说明，不收集身份证、手机号和详细住址。</view>
  </view>

  <view class="soft-card">
    <view class="field">
      <text class="label">阳历生日（必填）</text>
      <picker mode="date" value="{{birthday}}" bindchange="onBirthdayChange">
        <view class="picker-box {{birthday ? '' : 'placeholder'}}">{{birthday || '请选择日期'}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">出生时间（必填）</text>
      <picker mode="selector" range="{{hourOptions}}" value="{{hourIndex}}" bindchange="onHourChange">
        <view class="picker-box {{hourIndex >= 0 ? '' : 'placeholder'}}">{{hourIndex >= 0 ? hourOptions[hourIndex] : '请选择时段'}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">性别（必填）</text>
      <radio-group class="gender-row" bindchange="onGenderChange">
        <label class="gender-chip"><radio value="男" checked="{{gender === '男'}}" color="#0F5D57" />男</label>
        <label class="gender-chip"><radio value="女" checked="{{gender === '女'}}" color="#0F5D57" />女</label>
        <label class="gender-chip"><radio value="不便填写" checked="{{gender === '不便填写'}}" color="#0F5D57" />不便填写</label>
      </radio-group>
    </view>

    <view class="field">
      <text class="label">出生地（选填）</text>
      <input class="input" value="{{location}}" data-field="location" bindinput="onInput" placeholder="如：杭州" placeholder-class="placeholder" />
    </view>

    <view class="field">
      <text class="label">姓名（选填）</text>
      <input class="input" value="{{name}}" data-field="name" bindinput="onInput" placeholder="可留空" placeholder-class="placeholder" />
    </view>

    <view wx:if="{{error}}" class="error-box">{{error}}</view>

    <view wx:if="{{loading}}" class="loading-box">
      <view class="loading-spinner"></view>
      <view class="loading-label">{{loadingText}}</view>
    </view>

    <button class="primary-button" loading="{{loading}}" disabled="{{loading}}" bindtap="submit">{{loading ? loadingText : '开始推演'}}</button>
  </view>
</view>
