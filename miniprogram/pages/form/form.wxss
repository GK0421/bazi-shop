@import '/app.wxss';

.gender-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.gender-chip {
  padding: 16rpx 28rpx;
  border: 2rpx solid #d8e4d7;
  border-radius: 999rpx;
  background: #fff;
  color: #234a45;
  font-size: 28rpx;
}

.loading-box {
  margin-top: 32rpx;
  padding: 36rpx 28rpx;
  border-radius: 40rpx;
  background: rgba(255, 252, 244, 0.96);
  box-shadow: 0 18rpx 44rpx rgba(33, 76, 68, 0.13);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e8f5ee;
  border-top-color: #0f5d55;
  border-radius: 50%;
  animation: lds-spin 1s linear infinite;
}

@keyframes lds-spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-label {
  color: #936c1d;
  font-size: 28rpx;
  font-weight: 700;
  animation: lds-fade 1.8s ease-in-out infinite;
}

@keyframes lds-fade {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}
