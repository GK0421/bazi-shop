<view class="container">
  <view class="card">
    <view wx:if="{{report}}" style="font-size:36rpx;">
      <!-- 标题 -->
      <view wx:if="{{report.title}}" style="font-size:40rpx;font-weight:bold;color:#2D6A4F;margin-bottom:24rpx;text-align:center;">
        {{report.title}}
      </view>

      <!-- 基本信息 -->
      <view wx:if="{{input}}" style="background:#F5F5F5;border-radius:10rpx;padding:20rpx;margin-bottom:30rpx;font-size:26rpx;color:#666666;">
        <view style="margin-bottom:8rpx;"><text decode="true">生日：</text>{{input.birthday || '-'}}</view>
        <view style="margin-bottom:8rpx;"><text decode="true">时辰：</text>{{input.hour || '-'}}</view>
        <view style="margin-bottom:8rpx;"><text decode="true">性别：</text>{{input.gender || '-'}}</view>
        <view><text decode="true">出生地：</text>{{input.location || '-'}}</view>
      </view>

      <!-- 分析内容 -->
      <view wx:if="{{report.summary}}" style="font-size:30rpx;line-height:1.9;color:#333333;white-space:pre-wrap;margin-bottom:30rpx;">
        {{report.summary}}
      </view>

      <!-- 免责声明 -->
      <view wx:if="{{report.disclaimer}}" style="margin-top:40rpx;padding:24rpx;background:#FFF8E1;border-radius:10rpx;border-left:6rpx solid #C9A84C;">
        <view style="font-size:24rpx;color:#8B6914;line-height:1.8;">
          {{report.disclaimer}}
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!report}}" style="text-align:center;padding:60rpx 0;color:#999999;font-size:28rpx;">
      暂无分析结果
    </view>
  </view>

  <!-- 返回按钮 -->
  <view style="padding:0 30rpx;">
    <button class="btn-primary" bindtap="goHome" style="margin-top:0;">返回首页</button>
  </view>
</view>
