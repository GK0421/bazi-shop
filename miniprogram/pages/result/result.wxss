@import '/app.wxss';

.info-line {
  margin-top: 12rpx;
  color: #234a45;
  font-size: 28rpx;
  line-height: 1.6;
}

.disclaimer-card {
  border: 2rpx solid #f0c65d;
  background: #fffef5;
}

.audio-card {
  margin-top: 28rpx;
  padding: 28rpx;
  border-radius: 40rpx;
  background: rgba(255, 252, 244, 0.96);
  box-shadow: 0 18rpx 44rpx rgba(33, 76, 68, 0.13);
}

.audio-button {
  width: 100%;
  height: 80rpx;
  border-radius: 999rpx;
  background: #e8f5ee;
  color: #0f5d55;
  font-size: 30rpx;
  font-weight: 800;
  border: 2rpx solid #c3e0d0;
}

.error-text {
  margin-top: 12rpx;
  color: #cc6600;
  font-size: 26rpx;
}
