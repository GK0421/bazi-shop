<view class="container">
  <view class="title">今日人设签</view>
  <view class="form">
    <view class="form-item">
      <text>生日</text>
      <picker mode="date" bindchange="onBirthdayChange">
        <view class="picker">{{birthday || '请选择生日'}}</view>
      </picker>
    </view>
    <view class="form-item">
      <text>时辰</text>
      <picker mode="selector" range="{{hours}}" bindchange="onHourChange">
        <view class="picker">{{hours[hourIndex] || '请选择时辰'}}</view>
      </picker>
    </view>
    <view class="form-item">
      <text>性别</text>
      <radio-group bindchange="onGenderChange">
        <label><radio value="男" checked="{{gender==='男'}}"/>男</label>
        <label><radio value="女" checked="{{gender==='女'}}"/>女</label>
      </radio-group>
    </view>
    <view class="form-item">
      <text>出生地</text>
      <input placeholder="选填，如：北京" value="{{location}}" bindinput="onLocationInput" />
    </view>
    <button type="primary" bindtap="submit">开始分析</button>
  </view>
</view>
