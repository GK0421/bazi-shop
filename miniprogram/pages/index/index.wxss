.index-page {
  padding-top: 56rpx;
}

.shop-card {
  position: relative;
  overflow: hidden;
}

.shop-card::after {
  content: "";
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 150rpx;
  height: 150rpx;
  border-radius: 999rpx;
  background: #ffe0a1;
  opacity: 0.7;
}

.footer-note {
  margin-top: 36rpx;
  padding: 0 12rpx;
  color: #6f756c;
  font-size: 24rpx;
  line-height: 1.7;
  text-align: center;
}
