{
  "permissions": {
    "openapi": []
  },
  "env": {
    "LLM_PROVIDER": "kimi",
    "LLM_BASE_URL": "https://api.moonshot.cn/v1",
    "LLM_MODEL": "moonshot-v1-8k",
    "LLM_API_KEY": "sk-PASTE_YOUR_KEY_HERE"
  },
  "timeout": 60,
  "runtime": "Nodejs16.13",
  "_comment": "复制为 config.json 并填入真实 Kimi API Key"
}